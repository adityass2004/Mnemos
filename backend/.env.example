MNEMOS_GEMINI_API_KEY=your_gemini_api_key_here
MNEMOS_APP_ENV=production
MNEMOS_LOG_LEVEL=INFO
MNEMOS_CORS_ORIGINS=["https://your-app.vercel.app","http://localhost:5173"]
MNEMOS_MAX_UPLOAD_SIZE=104857600
MNEMOS_INGESTION_TIMEOUT=300
MNEMOS_MAX_RETRY_ATTEMPTS=3
MNEMOS_RETRY_DELAY=5.0
MNEMOS_TEMP_FILE_RETENTION_HOURS=24
MNEMOS_MAX_DOCUMENTS=1000
